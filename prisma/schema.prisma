// Schéma V1 — draft du PRD §6, complété des modèles NextAuth (Account,
// Session, VerificationToken, User.emailVerified) requis par le PrismaAdapter
// et le flow de vérification d'email repris du repo de référence.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  VA
  CLIENT
  ADMIN
}

enum Plan {
  ESSENTIELLE
  PRO
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String?
  lastName         String?
  password         String?
  role             Role      @default(VA)
  emailVerified    DateTime?
  stripeCustomerId String?   @unique
  // si role = CLIENT : rattachement au Client de la VA
  clientId         String?   @unique
  client           Client?   @relation(fields: [clientId], references: [id])
  createdAt        DateTime  @default(now())

  subscription Subscription?
  vaProfile    VaProfile?
  settings     UserSettings?
  clients      Client[]      @relation("VaClients")
  accounts     Account[]
  sessions     Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// D17 : profil annuaire public — opt-in strict, jamais publié par défaut.
model VaProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName  String
  headline     String?
  bio          String
  specialties  String[]
  location     String?
  region       String? // code région FR (idf, ara, naq…) pour la carte
  languages    String[]
  availability String   @default("available") // available | full
  availabilityNote String?
  contactEmail String?
  website      String?
  hourlyRate   Int? // €/h, affiché sur la fiche seulement
  capacityNote String? // « 10 h/mois »
  showStats    Boolean  @default(true) // stats auto sur la fiche publique
  published    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Réglages privés (maquette 30b). Stockés dès maintenant ; les notifications
// deviendront effectives avec l'envoi d'emails (Resend) et l'arrondi avec
// les rapports.
model UserSettings {
  id                     String  @id @default(cuid())
  userId                 String  @unique
  user                   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  notifyClientRequest    Boolean @default(true)
  notifyDirectoryContact Boolean @default(true)
  notifyLongTimer        Boolean @default(true)
  notifyWeeklyDigest     Boolean @default(false)
  timezone               String  @default("Europe/Paris")
  timerRounding          String  @default("quarter") // none | quarter | half
  weekStart              String  @default("monday")
  locale                 String  @default("fr")
}

model Subscription {
  id                   String             @id @default(cuid())
  vaId                 String             @unique
  va                   User               @relation(fields: [vaId], references: [id], onDelete: Cascade)
  plan                 Plan
  status               SubscriptionStatus
  stripeSubscriptionId String             @unique
  currentPeriodEnd     DateTime
}

model Client {
  id         String    @id @default(cuid())
  vaId       String
  va         User      @relation("VaClients", fields: [vaId], references: [id], onDelete: Cascade)
  name       String
  company    String?
  // Numéro 1-20 dans la palette clients du DESIGN.md — attribué à la
  // création, ne change jamais (pas recalculé par index de liste).
  color      Int       @default(1)
  // Taux horaire de ce client, en €/h (bloc CA de la fiche, maquette 32a).
  // Sert à estimer le chiffre d'affaires (heures trackées × taux) — jamais
  // affiché au client, jamais une facture.
  hourlyRate Int?
  // D15 : gouverne la visibilité des rapports générés sur le portail client.
  portalReportsEnabled Boolean @default(true)
  portalUser User?
  missions   Mission[]
  reports    Report[]
  procedures Procedure[]
  createdAt  DateTime  @default(now())
}

// D15 : un rapport « généré » par client × mois — action explicite de la VA.
// Le contenu (PDF, version portail) est rendu à la volée depuis les temps.
model Report {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  month       String // "2026-07"
  generatedAt DateTime @default(now())

  @@unique([clientId, month])
}

model Mission {
  id             String          @id @default(cuid())
  clientId       String
  client         Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name           String
  status         String          @default("active")
  tasks          Task[]
  recurringTasks RecurringTask[]
  createdAt      DateTime        @default(now())
}

// D16 : modèle de tâche récurrente — les occurrences sont des Task normales,
// générées paresseusement à l'ouverture (une par période, unique).
model RecurringTask {
  id          String   @id @default(cuid())
  missionId   String
  mission     Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)
  title       String
  cadence     String // weekly | monthly
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  occurrences Task[]
}

model Task {
  id              String         @id @default(cuid())
  missionId       String
  mission         Mission        @relation(fields: [missionId], references: [id], onDelete: Cascade)
  title           String
  done            Boolean        @default(false)
  // D19 : échéance optionnelle, date seule (pas d'heure) — auto pour les
  // occurrences récurrentes (fin de la période).
  dueDate         DateTime?      @db.Date
  source          String         @default("manual") // manual | meeting_sync | client_request | recurring
  recurringTaskId String?
  recurringTask   RecurringTask? @relation(fields: [recurringTaskId], references: [id], onDelete: SetNull)
  recurringPeriod String? // "2026-07" (monthly) | "2026-W31" (weekly)
  timeEntries     TimeEntry[]
  createdAt       DateTime       @default(now())

  @@unique([recurringTaskId, recurringPeriod])
}

model TimeEntry {
  id        String    @id @default(cuid())
  taskId    String
  task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label     String?
  startedAt DateTime
  endedAt   DateTime?
  // durée éditable a posteriori
}

// D22 : une procédure appartient à un client (pas de bibliothèque centrale).
// Consultation depuis la fiche client (VA) et le portail (client, lecture
// seule). Les templates SLC ne sont PAS stockés ici : ce sont des modèles
// proposés à la création (src/lib/sop-templates.ts).
model Procedure {
  id        String   @id @default(cuid())
  vaId      String
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title     String
  steps     String // HTML sanitizé (pattern TipTap + sanitize-html du repo)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
}

model MeetingItem {
  id         String   @id @default(cuid())
  vaId       String
  provider   String // fireflies | granola | fathom
  externalId String
  transcript String
  processed  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@unique([provider, externalId])
}

model Invoice {
  id             String   @id @default(cuid())
  vaId           String
  clientId       String
  periodStart    DateTime
  periodEnd      DateTime
  qontoInvoiceId String?  @unique
  amountCents    Int
  createdAt      DateTime @default(now())
}
